# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/real_estate_db
USE_SAMPLE_2024=1

# ── Anthropic Claude (optional) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── GCP Vertex AI ADK (optional) ─────────────────────────────────────────────
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# ── AWS credentials (SageMaker + Bedrock) ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── AWS SageMaker endpoints (optional) ───────────────────────────────────────
SAGEMAKER_RF_ENDPOINT=
SAGEMAKER_LR_ENDPOINT=

# ── AWS Bedrock model (optional) ─────────────────────────────────────────────
BEDROCK_MODEL_ID=amazon.titan-text-express-v1
